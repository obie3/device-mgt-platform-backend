# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
# In production, use a strong randomly generated password — never commit real
# credentials to version control.
DATABASE_URL="postgresql://dmp:CHANGE_ME_STRONG_PASSWORD@localhost:5432/dmp"
POSTGRES_USER=dmp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=dmp

# JWT
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_xxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# In production: set to your exact frontend origin, e.g. https://app.example.com
# Must NOT be * or http://localhost in production.
CORS_ORIGIN=http://localhost:3000

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=smtp_password
EMAIL_FROM="DMP <no-reply@example.com>"

# Frontend base URL (used in email links)
APP_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Storage provider
# ---------------------------------------------------------------------------
# Options: local | s3 | cloudinary
# local       — writes files to UPLOAD_DIR (default, no external deps)
# s3          — AWS S3 or any S3-compatible store (set S3_* vars below)
# cloudinary  — Cloudinary media platform (set CLOUDINARY_* vars below)
STORAGE_PROVIDER=local

# Local storage — must be writable; mount as a named volume in Docker
UPLOAD_DIR=./uploads/device-images

# S3 / S3-compatible (required when STORAGE_PROVIDER=s3)
# S3_BUCKET=my-dmp-bucket
# S3_REGION=eu-west-1
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_PUBLIC_BASE_URL=https://my-dmp-bucket.s3.eu-west-1.amazonaws.com
# S3_ENDPOINT=                 # Cloudflare R2 / MinIO only — leave blank for AWS

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=your_api_secret

# Slack (optional)
SLACK_WEBHOOK_URL=

# Initial admin user (used by seed script only — change before running in production)
SEED_ADMIN_EMAIL=admin@example.com
# Use a strong unique password — generate with: openssl rand -base64 16
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_SEEDING
SEED_ORG_NAME=My Organization
