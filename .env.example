# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
# In production, use a strong randomly generated password — never commit real
# credentials to version control.
DATABASE_URL="postgresql://dmp:CHANGE_ME_STRONG_PASSWORD@localhost:5432/dmp"
POSTGRES_USER=dmp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=dmp

# JWT
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_xxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# In production: set to your exact frontend origin, e.g. https://app.example.com
# Must NOT be * or http://localhost in production.
CORS_ORIGIN=http://localhost:3000

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=smtp_password
EMAIL_FROM="DMP <no-reply@example.com>"

# Frontend base URL (used in email links)
APP_BASE_URL=http://localhost:3000

# Slack (optional)
SLACK_WEBHOOK_URL=

# Initial admin user (used by seed script only — change before running in production)
SEED_ADMIN_EMAIL=admin@example.com
# Use a strong unique password — generate with: openssl rand -base64 16
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_SEEDING
SEED_ORG_NAME=My Organization
