generator client {
  provider      = "prisma-client-js"
  engineType    = "library" // embedded native module — no subprocess, faster cold start
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  admin
  operator
  viewer
}

enum DeviceType {
  laptop
  desktop
  mobile
  tablet
  server
  monitor
  printer
  networking
  other
}

enum DeviceStatus {
  in_stock      // received, not yet assigned
  assigned      // currently held by an employee
  under_repair  // sent for maintenance / repair
  decommissioned
}

enum EmployeeStatus {
  active
  offboarded
}

enum AlertType {
  unassigned_device
  warranty_expiry
}

enum ApprovalType {
  assignment
  decommission
  offboard
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

// ---------------------------------------------------------------------------
// Organizations — top-level tenant
// ---------------------------------------------------------------------------

model Organization {
  id                  String   @id @default(cuid())
  name                String   @db.VarChar(200)
  unassignedAlertDays Int      @default(7)  @map("unassigned_alert_days")
  settings            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt     @map("updated_at")

  users       User[]
  employees   Employee[]
  devices     Device[]
  departments Department[]
  locations   Location[]
  auditLogs   AuditLog[]
  approvals   Approval[]
  repairs     DeviceRepair[]

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// Users — platform login accounts (email + password, no OIDC)
// ---------------------------------------------------------------------------

model User {
  id                   String    @id @default(cuid())
  orgId                String    @map("org_id")
  name                 String    @db.VarChar(200)
  email                String    @db.VarChar(320)
  passwordHash         String    @map("password_hash")
  role                 UserRole  @default(viewer)
  isActive             Boolean   @default(true) @map("is_active")
  failedLoginAttempts  Int       @default(0)    @map("failed_login_attempts")
  lockedUntil          DateTime?               @map("locked_until")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt      @map("updated_at")

  org                 Organization         @relation(fields: [orgId], references: [id])
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  approvalRequests    Approval[]           @relation("ApprovalRequester")
  approvalReviews     Approval[]           @relation("ApprovalReviewer")
  repairsLogged       DeviceRepair[]

  @@unique([orgId, email])
  @@index([orgId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Refresh tokens
// ---------------------------------------------------------------------------

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Password reset tokens
// ---------------------------------------------------------------------------

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Employees — people who hold devices (not platform users)
// department stays as free-text string (not normalised in Phase 3)
// ---------------------------------------------------------------------------

model Employee {
  id           String         @id @default(cuid())
  orgId        String         @map("org_id")
  name         String         @db.VarChar(200)
  email        String         @db.VarChar(320)
  departmentId String?        @map("department_id")
  locationId   String?        @map("location_id")
  status       EmployeeStatus @default(active)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt     @map("updated_at")

  org         Organization       @relation(fields: [orgId], references: [id])
  department  Department?        @relation(fields: [departmentId], references: [id])
  location    Location?          @relation(fields: [locationId], references: [id])
  assignments DeviceAssignment[]
  approvals   Approval[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([departmentId])
  @@index([locationId])
  @@map("employees")
}

// ---------------------------------------------------------------------------
// Departments — org unit / budget owner (FK on Device)
// ---------------------------------------------------------------------------

model Department {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id])
  devices   Device[]
  employees Employee[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

// ---------------------------------------------------------------------------
// Locations — physical location (FK on Device, orthogonal to Department)
// ---------------------------------------------------------------------------

model Location {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt     @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id])
  devices   Device[]
  employees Employee[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// Devices
// ---------------------------------------------------------------------------

model Device {
  id           String       @id @default(cuid())
  orgId        String       @map("org_id")
  serial       String       @db.VarChar(100)
  type         DeviceType
  manufacturer String?      @db.VarChar(100)
  model        String       @db.VarChar(200)
  status       DeviceStatus @default(in_stock)

  // Asset identification
  assetTag     String?      @db.VarChar(50)   @map("asset_tag")
  // @@unique([orgId, assetTag]) — partial index in migration (WHERE asset_tag IS NOT NULL)

  // Departmental attribution (FK) and physical location (FK)
  departmentId String?      @map("department_id")
  locationId   String?      @map("location_id")

  // Cost tracking
  costCenter   String?      @db.VarChar(100)  @map("cost_center")

  // Procurement
  purchaseDate  DateTime?   @map("purchase_date")
  supplier      String?     @db.VarChar(200)
  purchasePrice Decimal?    @db.Decimal(10, 2) @map("purchase_price")

  // Warranty
  warrantyStart    DateTime? @map("warranty_start")
  warrantyEnd      DateTime? @map("warranty_end")
  warrantyProvider String?   @db.VarChar(200)  @map("warranty_provider")

  // Lifecycle
  decommissionReason String?  @db.VarChar(1000) @map("decommission_reason")
  notes              String?  @db.VarChar(2000)

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt      @map("updated_at")

  org         Organization       @relation(fields: [orgId], references: [id])
  department  Department?        @relation(fields: [departmentId], references: [id])
  location    Location?          @relation(fields: [locationId], references: [id])
  assignments DeviceAssignment[]
  alerts      Alert[]
  images      DeviceImage[]
  approvals   Approval[]
  repairs     DeviceRepair[]

  @@unique([orgId, serial])
  @@index([orgId])
  @@index([orgId, status])
  @@index([warrantyEnd])
  @@index([departmentId])
  @@index([locationId])
  @@map("devices")
}

// ---------------------------------------------------------------------------
// Device images
// ---------------------------------------------------------------------------

model DeviceImage {
  id           String   @id @default(cuid())
  deviceId     String   @map("device_id")
  filename     String   @db.VarChar(200)
  originalName String   @db.VarChar(500)  @map("original_name")
  size         Int
  mimeType     String   @db.VarChar(50)   @map("mime_type")
  createdAt    DateTime @default(now())   @map("created_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("device_images")
}

// ---------------------------------------------------------------------------
// Device assignments
// ---------------------------------------------------------------------------

model DeviceAssignment {
  id                   String    @id @default(cuid())
  deviceId             String    @map("device_id")
  employeeId           String    @map("employee_id")
  assignedAt           DateTime  @default(now()) @map("assigned_at")
  returnedAt           DateTime? @map("returned_at")
  conditionNotes       String?   @map("condition_notes") @db.VarChar(2000)
  acknowledgedAt       DateTime? @map("acknowledged_at")
  acknowledgeToken     String?   @unique @map("acknowledge_token")
  acknowledgeExpiresAt DateTime? @map("acknowledge_expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt     @map("updated_at")

  device   Device   @relation(fields: [deviceId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([deviceId])
  @@index([employeeId])
  @@index([acknowledgeToken])
  @@map("device_assignments")
}

// ---------------------------------------------------------------------------
// Alerts
// ---------------------------------------------------------------------------

model Alert {
  id         String    @id @default(cuid())
  deviceId   String    @map("device_id")
  type       AlertType
  message    String    @db.VarChar(500)
  sentAt     DateTime  @default(now()) @map("sent_at")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, type, resolvedAt])
  @@index([deviceId])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
// Audit log — append-only
// ---------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  userId       String?  @map("user_id")
  action       String   @db.VarChar(100)
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String   @map("resource_id")
  payload      Json     @default("{}")
  ts           DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id])
  user User?        @relation(fields: [userId], references: [id])

  @@index([orgId, ts])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Approvals — governance workflow (operator requests, admin approves/rejects)
// ---------------------------------------------------------------------------

model Approval {
  id          String         @id @default(cuid())
  orgId       String         @map("org_id")
  type        ApprovalType
  status      ApprovalStatus @default(pending)
  requestedBy String         @map("requested_by")
  reviewedBy  String?        @map("reviewed_by")
  // Nullable: offboard approvals have no deviceId; decommission approvals have no employeeId
  deviceId    String?        @map("device_id")
  employeeId  String?        @map("employee_id")
  // Stores the action parameters needed to execute on approval
  payload     Json           @default("{}")
  reviewNote  String?        @db.VarChar(1000) @map("review_note")
  createdAt   DateTime       @default(now())   @map("created_at")
  resolvedAt  DateTime?      @map("resolved_at")

  org       Organization @relation(fields: [orgId], references: [id])
  requester User         @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  reviewer  User?        @relation("ApprovalReviewer",  fields: [reviewedBy],  references: [id])
  device    Device?      @relation(fields: [deviceId],   references: [id], onDelete: SetNull)
  employee  Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([requestedBy])
  @@index([deviceId])
  @@index([employeeId])
  @@map("approvals")
}

// ---------------------------------------------------------------------------
// Device repairs — maintenance / repair tracking (Phase 5)
// ---------------------------------------------------------------------------

model DeviceRepair {
  id                String    @id @default(cuid())
  orgId             String    @map("org_id")
  deviceId          String    @map("device_id")
  loggedById        String?   @map("logged_by_id")

  // Problem description
  issue             String    @db.Text
  notes             String?   @db.Text

  // Repair vendor / technician
  vendor            String?   @db.VarChar(200)
  technicianName    String?   @db.VarChar(200) @map("technician_name")

  // Cost
  cost              Decimal?  @db.Decimal(12, 2)

  // Timeline
  sentAt            DateTime  @default(now()) @map("sent_at")
  estimatedReturnAt DateTime? @map("estimated_return_at")
  returnedAt        DateTime? @map("returned_at")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt      @map("updated_at")

  org      Organization @relation(fields: [orgId],      references: [id])
  device   Device       @relation(fields: [deviceId],   references: [id], onDelete: Cascade)
  loggedBy User?        @relation(fields: [loggedById], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([orgId])
  @@map("device_repairs")
}
