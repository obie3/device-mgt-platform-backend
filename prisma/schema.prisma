generator client {
  provider   = "prisma-client-js"
  engineType = "library" // embedded native module — no subprocess, faster cold start
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  admin
  operator
  viewer
}

enum DeviceType {
  laptop
  desktop
  mobile
  tablet
  server
  monitor
  printer
  networking
  other
}

enum DeviceStatus {
  active
  decommissioned
}

enum EmployeeStatus {
  active
  offboarded
}

enum AlertType {
  unassigned_device
}

// ---------------------------------------------------------------------------
// Organizations — top-level tenant
// ---------------------------------------------------------------------------

model Organization {
  id                  String   @id @default(cuid())
  name                String   @db.VarChar(200)
  unassignedAlertDays Int      @default(7)  @map("unassigned_alert_days")
  settings            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt     @map("updated_at")

  users       User[]
  employees   Employee[]
  devices     Device[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// Users — platform login accounts (email + password, no OIDC)
// Email is unique per org. Login resolves by email across orgs (first match
// for the given credentials wins — acceptable since email domains are
// typically org-scoped in practice).
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  name         String   @db.VarChar(200)
  email        String   @db.VarChar(320)
  passwordHash String   @map("password_hash")
  role         UserRole @default(viewer)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt     @map("updated_at")

  org                 Organization         @relation(fields: [orgId], references: [id])
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]

  @@unique([orgId, email])
  @@index([orgId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Refresh tokens — hashed, one row per issued token
// ---------------------------------------------------------------------------

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Password reset tokens — hashed, one row per requested reset
// ---------------------------------------------------------------------------

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Employees — people who hold devices (not platform users)
// ---------------------------------------------------------------------------

model Employee {
  id         String         @id @default(cuid())
  orgId      String         @map("org_id")
  name       String         @db.VarChar(200)
  email      String         @db.VarChar(320)
  department String?        @db.VarChar(100)
  status     EmployeeStatus @default(active)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt     @map("updated_at")

  org         Organization       @relation(fields: [orgId], references: [id])
  assignments DeviceAssignment[]

  @@unique([orgId, email])
  @@index([orgId])
  @@map("employees")
}

// ---------------------------------------------------------------------------
// Devices — no check-in fields (tokenHash / hostname / lastSeen removed)
// ---------------------------------------------------------------------------

model Device {
  id           String       @id @default(cuid())
  orgId        String       @map("org_id")
  serial       String       @db.VarChar(100)
  type         DeviceType
  manufacturer String?      @db.VarChar(100)
  model        String       @db.VarChar(200)
  purchaseDate DateTime?    @map("purchase_date")
  notes                String?      @db.VarChar(2000)
  status               DeviceStatus @default(active)
  decommissionReason   String?      @db.VarChar(1000) @map("decommission_reason")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt     @map("updated_at")

  org         Organization       @relation(fields: [orgId], references: [id])
  assignments DeviceAssignment[]
  alerts      Alert[]
  images      DeviceImage[]

  @@unique([orgId, serial])
  @@index([orgId])
  @@map("devices")
}

// ---------------------------------------------------------------------------
// Device images — up to 5 images per device, stored on the filesystem
// ---------------------------------------------------------------------------

model DeviceImage {
  id           String   @id @default(cuid())
  deviceId     String   @map("device_id")
  filename     String   @db.VarChar(200)  // stored name on disk (UUID-based)
  originalName String   @db.VarChar(500)  @map("original_name")
  size         Int                         // bytes
  mimeType     String   @db.VarChar(50)   @map("mime_type")
  createdAt    DateTime @default(now())   @map("created_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@map("device_images")
}

// ---------------------------------------------------------------------------
// Device assignments — one open row per device (returned_at IS NULL = active)
// ---------------------------------------------------------------------------

model DeviceAssignment {
  id                   String    @id @default(cuid())
  deviceId             String    @map("device_id")
  employeeId           String    @map("employee_id")
  assignedAt           DateTime  @default(now()) @map("assigned_at")
  returnedAt           DateTime? @map("returned_at")
  conditionNotes       String?   @map("condition_notes") @db.VarChar(2000)
  acknowledgedAt       DateTime? @map("acknowledged_at")
  acknowledgeToken     String?   @unique @map("acknowledge_token")
  acknowledgeExpiresAt DateTime? @map("acknowledge_expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt     @map("updated_at")

  device   Device   @relation(fields: [deviceId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([deviceId])
  @@index([employeeId])
  @@index([acknowledgeToken])
  @@map("device_assignments")
}

// ---------------------------------------------------------------------------
// Alerts
// ---------------------------------------------------------------------------

model Alert {
  id         String    @id @default(cuid())
  deviceId   String    @map("device_id")
  type       AlertType
  message    String    @db.VarChar(500)
  sentAt     DateTime  @default(now()) @map("sent_at")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, type, resolvedAt]) // dedup: one open alert per device per type
  @@index([deviceId])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
// Audit log — append-only, never updated or deleted
// ---------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  userId       String?  @map("user_id") // null for system actions (jobs)
  action       String   @db.VarChar(100) // e.g. device.created, user.login
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String   @map("resource_id")
  payload      Json     @default("{}")
  ts           DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id])
  user User?        @relation(fields: [userId], references: [id])

  @@index([orgId, ts])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}
